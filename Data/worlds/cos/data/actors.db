sity":5,"reverse":false},"darkness":{"min":0,"max":1}},"sight":{"enabled":false,"range":null,"angle":360,"visionMode":"basic","color":null,"attenuation":0.1,"brightness":0,"saturation":0,"contrast":0},"detectionModes":[],"flags":{},"randomImg":false},"items":[{"_id":"05eiZGXWoOZ8kTBc","name":"Angeborenes Zauberwirken","ownership":{"default":0,"YzL2W1htQr2gHsBA":3},"type":"feat","system":{"description":{"value":"<p>Das Attribut zum Wirken angeborener Zauber für den Cambion ist Charisma (Zauberrettungswurf-SG 14). Er kann von Natur aus die folgenden Zauber wirken, wobei keine Materialkomponenten notwendig sind:</p><p>Jeweils 3/Tag:</p><ul><li><p>@UUID[Compendium.dnd5e.spells.arzCrMRgcNiQuh43]{Befehl}</p></li><li><p>@UUID[Compendium.dnd5e.spells.8RTDOt80u8aBv9qx]{Gestalt verändern}</p></li></ul><p>Jeweils 1/Tag:</p><ul><li><p>@UUID[Compendium.dnd5e.spells.J6Jpw5XzB5aTeqnz]{Ebenenwechsel}</p></li></ul>","chat":"","unidentified":""},"source":"SRD 5.1","activation":{"type":"","cost":null,"condition":""},"duration":{"value":"","units":""},"cover":null,"crewed":false,"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"long":null,"units":""},"uses":{"value":null,"max":"","per":null,"recovery":""},"consume":{"type":"","target":null,"amount":null},"ability":"","actionType":"","attackBonus":"","chatFlavor":"","critical":{"threshold":null,"damage":""},"damage":{"parts":[],"versatile":""},"formula":"","save":{"ability":"","dc":null,"scaling":"spell"},"type":{"value":"monster","subtype":""},"requirements":"","recharge":{"value":null,"charged":false}},"flags":{"babele":{"translated":true,"hasTranslation":true,"originalName":"Innate Spellcasting"},"core":{"sourceId":"Compendium.dnd5e.monsterfeatures.hkmTEk6klT6QL4K4"}},"img":"icons/magic/light/projectiles-star-purple.webp","effects":[],"folder":null,"sort":0,"_stats":{"systemId":"dnd5e","systemVersion":"2.2.2","coreVersion":"10.291","createdTime":1661787234583,"modifiedTime":1695479993938,"lastModifiedBy":"YzL2W1htQr2gHsBA"}},{"_id":"zf26FVeU1Vcfgp3V","name":"Mehrfachangriff","ownership":{"default":0,"YzL2W1htQr2gHsBA":3},"type":"feat","system":{"description":{"value":"<p>Die {creature} führt in einer Aktion eine Reihe von Angriffen aus. Diese Angriffe können vom gleichen Typ sein oder eine gemischte Variante ihrer Angriffsaktionen.</p>","chat":"","unidentified":""},"source":"SRD 5.1","activation":{"type":"action","cost":1,"condition":""},"duration":{"value":"","units":""},"cover":null,"crewed":false,"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"long":null,"units":""},"uses":{"value":null,"max":"","per":null,"recovery":""},"consume":{"type":"","target":null,"amount":null},"ability":null,"actionType":"","attackBonus":"","chatFlavor":"","critical":{"threshold":null,"damage":""},"damage":{"parts":[],"versatile":""},"formula":"","save":{"ability":"","dc":null,"scaling":"spell"},"type":{"value":"monster","subtype":""},"requirements":"","recharge":{"value":null,"charged":false}},"flags":{"babele":{"translated":true,"hasTranslation":true,"originalName":"Multiattack"},"core":{"sourceId":"Compendium.dnd5e.monsterfeatures.EqoLg8T8EHvhJgKE"}},"img":"icons/skills/melee/blade-tips-triple-steel.webp","effects":[],"folder":null,"sort":0,"_stats":{"systemId":"dnd5e","systemVersion":"2.2.2","coreVersion":"10.291","createdTime":1661787234520,"modifiedTime":1695480014242,"lastModifiedBy":"YzL2W1htQr2gHsBA"}},{"name":"Feuerstrahl","type":"feat","system":{"description":{"value":"","chat":"","unidentified":""},"source":"","activation":{"type":"action","cost":1,"condition":""},"duration":{"value":"","units":""},"cover":null,"crewed":false,"target":{"value":null,"width":null,"units":"","type":"creature"},"range":{"value":36,"long":null,"units":"m"},"uses":{"value":null,"max":"","per":null,"recovery":""},"consume":{"type":"","target":null,"amount":null},"ability":"","actionType":"rsak","attackBonus":"+7","chatFlavor":"","critical":{"threshold":null,"damage":""},"damage":{"parts":[["3d6","fire"]],"versatile":""},"formula":"","save":{"ability":"","dc":null,"scaling":"spell"},"type":{"value":"monster","subtype":""},"requirements":"","recharge":{"value":null,"charged":false}},"_id":"6USK9EjGrLsEPeDZ","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0,"YzL2W1htQr2gHsBA":3},"flags":{},"_stats":{"systemId":"dnd5e","systemVersion":"2.2.2","coreVersion":"10.291","createdTime":1695480068645,"modifiedTime":1695480210690,"lastModifiedBy":"YzL2W1htQr2gHsBA"}},{"name":"Teuflischer Charme","type":"feat","system":{"description":{"value":"<p>Ein Humanoid innerhalb von 9m, den der Cambion sehen kann, muss einen Weisheitsrettungswurf gegen SG 14 ablegen, um nicht für einen Tag magisch bezaubert zu werden.</p><p>Das bezauberte Ziel gehorcht den gesprochenen Befehlen des Cambions. Wenn das Ziel Schaden durch den Cambion oder eine andere Kreatur erleidet oder einen selbstmörderischen Befehl vom Cambion erhält, kann das Ziel den Rettungswurf wiederholen, was den Effekt bei einem Erfolg beendet.</p><p>Wenn der Rettungswurfe erfolgreich ist oder der Effekt endet, dann ist die Kreatur für die nächsten 24h gegen den Teuflischen Charme des Cambinos immun.</p>","chat":"","unidentified":""},"source":"","activation":{"type":"action","cost":1,"condition":""},"duration":{"value":"24","units":"inst"},"cover":null,"crewed":false,"target":{"value":1,"width":null,"units":"","type":"creature"},"range":{"value":9,"long":null,"units":"m"},"uses":{"value":null,"max":"","per":null,"recovery":""},"consume":{"type":"","target":null,"amount":null},"ability":"","actionType":"save","attackBonus":"","chatFlavor":"","critical":{"threshold":null,"damage":""},"damage":{"parts":[],"versatile":""},"formula":"","save":{"ability":"wis","dc":14,"scaling":"flat"},"type":{"value":"race","subtype":""},"requirements":"","recharge":{"value":null,"charged":false}},"_id":"vpjeYuOOUehqD3a2","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0,"YzL2W1htQr2gHsBA":3},"flags":{},"_stats":{"systemId":"dnd5e","systemVersion":"2.2.2","coreVersion":"10.291","createdTime":1695480272948,"modifiedTime":1695480612692,"lastModifiedBy":"YzL2W1htQr2gHsBA"}},{"name":"Speer","type":"feat","system":{"description":{"value":"","chat":"","unidentified":""},"source":"","activation":{"type":"action","cost":1,"condition":""},"duration":{"value":"","units":""},"cover":null,"crewed":false,"target":{"value":1,"width":null,"units":"","type":"creature"},"range":{"value":1.5,"long":18,"units":"m"},"uses":{"value":null,"max":"","per":null,"recovery":""},"consume":{"type":"","target":null,"amount":null},"ability":"","actionType":"mwak","attackBonus":"7","chatFlavor":"","critical":{"threshold":null,"damage":""},"damage":{"parts":[["1d6+4","piercing"],["1d6","fire"]],"versatile":"1d7+4"},"formula":"","save":{"ability":"","dc":null,"scaling":"spell"},"type":{"value":"","subtype":""},"requirements":"","recharge":{"value":null,"charged":false}},"_id":"5epQ9dTYQsWeH9DI","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0,"YzL2W1htQr2gHsBA":3},"flags":{},"_stats":{"systemId":"dnd5e","systemVersion":"2.2.2","coreVersion":"10.291","createdTime":1695480617091,"modifiedTime":1695480781841,"lastModifiedBy":"YzL2W1htQr2gHsBA"}}],"effects":[],"sort":0,"ownership":{"default":0,"YzL2W1htQr2gHsBA":3},"flags":{},"_stats":{"systemId":"dnd5e","systemVersion":"2.2.2","coreVersion":"10.291","createdTime":1695478581285,"modifiedTime":1695480781841,"lastModifiedBy":"YzL2W1htQr2gHsBA"},"_id":"ORh73835tkEdsaIb"}
{"name":"Thiala","type":"character","img":"Player%20Avatar%20Images/thiala_player.png","system":{"abilities":{"str":{"value":8,"proficient":0,"bonuses":{"check":"","save":""}},"dex":{"value":15,"proficient":1,"bonuses":{"check":"","save":""}},"con":{"value":10,"proficient":0,"bonuses":{"check":"","save":""}},"int":{"value":14,"proficient":0,"bonuses":{"check":"","save":""}},"wis":{"value":12,"proficient":0,"bonuses":{"check":"","save":""}},"cha":{"value":18,"proficient":1,"bonuses":{"check":"","save":""}}},"attributes":{"ac":{"flat":null,"calc":"default","formula":""},"hp":{"value":12,"max":28,"temp":null,"tempmax":null,"bonuses":{"level":"","overall":""}},"init":{"ability":"dex","bonus":""},"movement":{"burrow":0,"climb":0,"fly":0,"swim":0,"walk":9,"units":"m","hover":false},"attunement":{"max":3},"senses":{"darkvision":60,"blindsight":0,"tremorsense":0,"truesight":0,"units":"ft","special":""},"spellcasting":"cha","death":{"success":0,"failure":0},"exhaustion":0,"inspiration":false},"details":{"biography":{"value":"","public":""},"alignment":"True Neutral","race":"Tiefling","background":"","originalClass":"YCEAw06KVgAuhL2A","xp":{"value":0},"appearance":"Hörner auf dem Kopf, \nblass lilafarbene Haut,\nSchwanz","trait":"Ich mag es, mich in enge Orte zu quetschen, an denen mich niemand erreichen kann. \n\nGeschichte: Nicht einmal 5 Minuten wanderte meine Seele auf dieser Welt, als der Gatte meiner Mutter zum ersten Mal die kleinen Hörner auf meiner Stirn und die blass lilafarbene Haut erblickte. Auf einen Schlag wurde ihm klar, dass ich ein Bastard war, der das Ansehen der noblen Calon Familie gefährden könnte. Noch im selben Augenblick riss er mich aus den Armen meiner schluchzenden Mutter und drohte, mich aus dem Fenster zu werfen, um meinem niederen Tiefling-Dasein ein jähes Ende zu bereiten und nicht noch mehr Schande über die Familie zu bringen. Dass ich heute noch lebe, verdanke ich der Hebamme Gertrude, welche seit jeher in den Diensten der Familie war. Sie nahm mich an sich, versprach dem Familienoberhaupt sich stillschweigend um dieses \"Missgeschick\", wie sie es nannte, zu kümmern, nur um mich dann auf die Treppen eines Waisenhauses zu legen. So wurde ich also schon als kleines Baby durch meine Eltern verstossen und wuchs von da an in einem Waisenhaus auf. \nDie Zeit verging und mit jedem Jahr wurde ich nicht nur grösser, sondern lernte auch, mich gegen die steten Gemeinheiten der anderen Waisenkinder zu wehren und das Misstrauen, welches die Menschheit seit jeher Tieflingen wie mir entgegenbrachte, zu akzeptieren. Auch wenn ihre Worte im Herzen weiterhin wehtaten, wurde ich von Jahr zu Jahr besser darin, meine gebrochene innere Seele durch ein fröhliches äusseres zu überdecken und es war mir sogar möglich, die zarten Bande der Freundschaft mit einigen anderen Waisenkindern zu knüpfen.\nDieses glückliche Dasein endete jedoch abrupt als ich mich, gerade 14 Jahre alt geworden, einem der gemeinsten Waisenkinder etwas zu heftig entgegensetzte, um einen meiner wenigen Freunde zu beschützen. Ein gebrochener Arm, zwei gebrochene Rippen und meine Verbannung aus dem Waisenhaus waren das Ergebnis dieser unschönen Rauferei.\nAuf mich allein gestellt wanderte ich von nun an durch die Strassen meiner Heimatstadt, stetig auf der Suche nach Essen, Wärme und Geborgenheit. Letzteres fand ich zum ersten Mal, als ich meinem Freund Mr. Twizzels begegnete. Einer zu klein geratenen Strassenratte, stetig auf Nahrungssuche, genau so wie ich auch. Als ich Mr. Twizzels mein letztes Stückchen Käse anbot, schien unsere Freundschaft auf ewig besiegelt und er wurde von diesem Tage an mein treuer Begleiter. \nMeine zweite Begegnung mit der Geborgenheit machte ich, als ein seltsam gekleideter Mann zum ersten Mal unsere Stadt betrat. Er war gross gewachsen, mit langem Bart und weiter Kutte und er hatte ein schwarzes, vollbepacktes Pferd im Schlepptau. Zudem trug er stets einen merkwürdig aussehenden Gegenstand auf seinem Rücken.\nWorum es sich hierbei handelte, begriff ich zum ersten Mal als ich eines schönen Abends den Marktplatz im Stadtzentrum aufsuchte. In der Hoffnung, etwas Essbares zu finden, hörte ich auf einmal den kräftigen Gesang einer tiefen, männlichen Stimme und ich entdeckte den Fremdling, umringt von schaulustigen Zuhörern, sitzend auf dem Rand des Dorfbrunnens. Seine Stimme war tief, tiefer als ich je eine Stimme vermocht hatte zu hören und so rau, dass sie einem sofort Gänsehaut bescherte. Und dennoch zog diese melodische Stimme mich magisch an und ich konnte nicht mehr aufhören, ihr zu lauschen. Die Lieder, welche er sang, erzählten von fernen Welten, ruhmreichen Helden, gefährlichen Drachen und wahnwitzigen Feen und sonstigen Wesen, von welchen ich noch nie gehört hatte, geschweige denn in meinem Dasein als Strassenkind je geglaubt hätte eines Tages erblicken zu können. Diese magische Welt, welche er mit der blossen Kraft seiner Stimme zu erschaffen schien, faszinierte mich von der ersten Sekunde an und ich lauschte dem Sänger den ganzen Abend. Als seine Stimme weit nach Mitternacht endlich verstummte, packte ich die Gelegenheit, um mich vorzustellen. Dadurch erfuhr ich, dass es sich bei dem Fremden um einen wandernden Barden handelte, welcher durch die ganze Welt reiste, um die Geschichten und Lieder grosser Helden darzubieten. Nachdem ich dem Barden mit grosser Begeisterung meine eigene Geschichte erzählt hatte, meinte er, ich hätte ein gewisses Talent, kleine Geschichten gross erscheinen zu lassen, und, dass er auf der Suche nach einer helfenden Hand sei, die ihm bei seinen Reisen zur Seite stehen würde. Ich willigte sofort ein und von diesem Tage an wanderten wir gemeinsam durch die Welt, erzählten Geschichten, sangen Lieder und gaben uns gegenseitig das zu Hause, welches wir vorher nie hatten. \nSo zogen die Jahre ins Land und ich genoss eine hervorragende Ausbildung in allen Künsten des Barden-Daseins durch meinen persönlichen Mentor, welcher mir nicht nur Gesang, Magie und Weltoffenheit lehrte, sondern auch Rechtschaffenheit und den Umgang mit allerlei Instrumenten. Diese schöne Zeit endete, als sich mein Mentor mit den Worten: «Jede Geschichte in einem Lied muss einmal ausklingen, meine neigt sich nun dem Ende zu.» zur Ruhe setzte und mir auftrug, unsere gemeinsame Reise allein fortzusetzen. So verabschiedete ich mich also von meinem langjährigen Freund und Mentor, packte den in die Jahre gekommenen, aber immer noch fitten Mr. Twizzels auf meine Schulter und zog alleine los in die weite Welt...","ideal":"Strassenkind: \nGeheimnisse der Stadt: You know the secret patterns and flow to cities and can\nfind passages through the urban sprawl that others would\nmiss. When you are not in combat, you (and companions\nyou lead) can travel between any two locations in the city\ntwice as fast as your speed would normally allow","bond":"Ich verdanke mein Überleben einem anderen Strassenkind, das mir beigebracht hat, wie man in den Gassen zurechtkommt.","flaw":"Wenn ich in Unterzahl bin, fliehe ich vor einem Kampf."},"traits":{"size":"med","di":{"value":[],"bypasses":[],"custom":""},"dr":{"value":["fire"],"bypasses":[],"custom":""},"dv":{"value":[],"bypasses":[],"custom":""},"ci":{"value":[],"custom":""},"languages":{"value":["common","infernal"],"custom":""},"weaponProf":{"value":["sim","handcrossbow","longsword","rapier","shortsword"],"custom":""},"armorProf":{"value":["lgt"],"custom":""},"toolProf":{"value":[],"custom":""}},"currency":{"pp":0,"gp":195,"ep":0,"sp":149,"cp":50},"skills":{"acr":{"value":0.5,"ability":"dex","bonuses":{"check":"","passive":""}},"ani":{"value":0.5,"ability":"wis","bonuses":{"check":"","passive":""}},"arc":{"value":0.5,"ability":"int","bonuses":{"check":"","passive":""}},"ath":{"value":0.5,"ability":"str","bonuses":{"check":"","passive":""}},"dec":{"value":1,"ability":"cha","bonuses":{"check":"","passive":""}},"his":{"value":0.5,"ability":"int","bonuses":{"check":"","passive":""}},"ins":{"value":0.5,"ability":"wis","bonuses":{"check":"","passive":""}},"itm":{"value":0.5,"ability":"cha","bonuses":{"check":"","passive":""}},"inv":{"value":0.5,"ability":"int","bonuses":{"check":"","passive":""}},"med":{"value":2,"ability":"wis","bonuses":{"check":"","passive":""}},"nat":{"value":0.5,"ability":"int","bonuses":{"check":"","passive":""}},"prc":{"value":2,"ability":"wis","bonuses":{"check":"","passive":""}},"prf":{"value":1,"ability":"cha","bonuses":{"check":"","passive":""}},"per":{"value":0.5,"ability":"cha","bonuses":{"check":"","passive":""}},"rel":{"value":0.5,"ability":"int","bonuses":{"check":"","passive":""}},"slt":{"value":1,"ability":"dex","bonuses":{"check":"","passive":""}},"ste":{"value":1,"ability":"dex","bonuses":{"check":"","passive":""}},"sur":{"value":1,"ability":"wis","bonuses":{"check":"","passive":""}}},"tools":{},"spells":{"spell1":{"value":2,"override":null},"spell2":{"value":3,"override":null},"spell3":{"value":1,"override":null},"spell4":{"value":0,"override":null},"spell5":{"value":0,"override":null},"spell6":{"value":0,"override":null},"spell7":{"value":0,"override":null},"spell8":{"value":0,"override":null},"spell9":{"value":0,"override":null},"pact":{"value":0,"override":null},"spell0":{"value":3}},"bonuses":{"mwak":{"attack":"","damage":""},"rwak":{"attack":"","damage":""},"msak":{"attack":"","damage":""},"rsak":{"attack":"","damage":""},"abilities":{"check":"","save":"","skill":""},"spell":{"dc":""}},"resources":{"primary":{"value":1,"max":4,"sr":true,"lr":true,"label":"Bardic Inspiration"},"secondary":{"value":null,"max":null,"sr":false,"lr":false,"label":""},"tertiary":{"value":null,"max":null,"sr":false,"lr":false,"label":""}}},"prototypeToken":{"name":"Thiala","displayName":0,"actorLink":true,"texture":{"src":"Player%20Avatar%20Images/thiala_avatar.png","scaleX":1,"scaleY":1,"offsetX":0,"offsetY":0,"rotation":0,"tint":null},"width":1,"height":1,"lockRotation":false,"rotation":0,"alpha":1,"disposition":1,"displayBars":0,"bar1":{"attribute":"attributes.hp"},"bar2":{"attribute":null},"light":{"alpha":0.5,"angle":360,"bright":0,"color":null,"coloration":1,"dim":0,"attenuation":0.5,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"type":null,"speed":5,"intensity":5,"reverse":false},"darkness":{"min":0,"max":1}},"sight":{"enabled":true,"range":60,"angle":360,"visionMode":"darkvision","color":null,"attenuation":0,"brightness":0,"saturation":-1,"contrast":0},"detectionModes":[],"flags":{},"randomImg":false},"items":[{"name":"Schule des Wissens","type":"subclass","system":{"description":{"value":"<h1>Description</h1><p class=\"Core-Styles_Core-Body\">Bards of the College of Lore know something about most things, collecting bits of knowledge from sources as diverse as scholarly tomes and peasant tales. Whether singing folk ballads in taverns or elaborate compositions in royal courts, these bards use their gifts to hold audiences spellbound. When the applause dies down, the audience members might find themselves questioning everything they held to be true, from their faith in the priesthood of the local temple to their loyalty<span class=\"No-Break\"> to the king.</span></p><h1>Class Features</h1>\n\n<p><b>Bonus Proficiencies</b></p>\n<p>When you join the College of Lore at 3rd level, you gain proficiency with three skills of your choice.</p>\n\n<p><b>Cutting Words</b></p>\n<p>Also at 3rd level, you learn how to use your wit to distract, confuse, and otherwise sap the confidence and competence of others. When a creature that you can see within 60 feet of you makes an attack roll, an ability check, or a damage roll, you can use your reaction to expend one of your uses of Bardic Inspiration, rolling a Bardic Inspiration die and subtracting the number rolled from the creature’s roll. You can choose to use this feature after the creature makes its roll, but before the DM determines whether the attack roll or ability check succeeds or fails, or before the creature deals its damage. The creature is immune if it can’t hear you or if it’s immune to being @Compendium[dnd5e.rules.w7eitkpD7QQTB6j0]{charmed}.</p>\n\n<p><b>Additional Magical Secrets</b></p>\n<p>At 6th level, you learn two spells of your choice from any class. A spell you choose must be of a level you can cast, as shown on the Bard table, or a cantrip. The chosen spells count as bard spells for you but don’t count against the number of bard spells you know.</p>\n\n<p><b>Peerless Skill</b></p>\n<p>Starting at 14th level, when you make an ability check, you can expend one use of Bardic Inspiration. Roll a Bardic Inspiration die and add the number rolled to your ability check. You can choose to do so after you roll the die for the ability check, but before the DM tells you whether you succeed or fail.</p>","chat":"","unidentified":""},"source":"","identifier":"college-of-lore","classIdentifier":"bard","advancement":[],"spellcasting":{"progression":"none","ability":""}},"flags":{"ddbimporter":{"subclassDefinitionId":141569506,"id":18,"type":"class","importId":"H5jtN7tByd3SNWB0"},"obsidian":{"source":{"type":"class","text":"College of Lore"}}},"img":"icons/skills/trades/academics-book-study-runes.webp","effects":[],"_id":"BvvKTMETRGIm3ao7","folder":null,"sort":0,"ownership":{"default":0,"YzL2W1htQr2gHsBA":3},"_stats":{"systemId":"dnd5e","systemVersion":"2.2.2","coreVersion":"10.291","createdTime":1692382155101,"modifiedTime":1693094044144,"lastModifiedBy":"YzL2W1htQr2gHsBA"}},{"name":"Barde","type":"class","system":{"description":{"value":"<p>Als Barde erhältst du die folgenden Klassenmerkmale:</p>\n<h3>Trefferpunkte</h3>\n<p><strong>Trefferwürfel:</strong> 1W8 pro Stufe als Barde<br /><strong>Trefferpunkte auf Stufe 1:</strong> 8 + dein Konstitutionsmodifikator<br /><strong>Trefferpunkte auf höheren Stufen:</strong> 1W8 (oder 5) + dein Konstitutionsmodifikator pro Stufe als Barde über die 1. Stufe hinaus</p>\n<h3>Übung</h3>\n<p><strong>Rüstungen:</strong> leichte Rüstungen<br /><strong>Waffen:</strong> einfache Waffen, Handarmbrüste, Langschwerter, Rapiere und Kurzschwerter<br /><strong>Werkzeuge:</strong> drei Musikinstrumente deiner Wahl<br /><strong>Rettungswürfe:</strong> Geschicklichkeit, Charisma<br /><strong>Fertigkeiten:</strong> drei beliebige deiner Wahl</p>\n<h3>Ausrüstung</h3>\n<p>Du beginnst mit der folgenden Ausrüstung, zusätzlich zu der, die du durch deinen Hintergrund erhältst:</p>\n<ul>\n<li>(a) ein @UUID[Compendium.dnd5e.items.Tobce1hexTnDk4sV]{Rapier}, (b) ein @UUID[Compendium.dnd5e.items.10ZP2Bu3vnCuYMIB]{Langschwert} oder (c) eine einfache Waffe,</li>\n<li>(a) Diplomatenausrüstung oder (b) Unterhaltungskünstler-Ausrüstung,</li>\n<li>(a) eine @UUID[Compendium.dnd5e.items.qBydtUUIkv520DT7]{Laute} oder (b) ein anderes Musikinstrument,</li>\n<li>eine @UUID[Compendium.dnd5e.items.WwdpHLXGX5r8uZu5]{Lederrüstung} und ein @UUID[Compendium.dnd5e.items.0E565kQUBmndJ1a2]{Dolch}.</li>\n</ul>\n<h1>Barde Aufstiegstabelle</h1>\n<table>\n<thead>\n<tr>\n<td>Stufe</td>\n<td>Übungsbonus</td>\n<td>Merkmale</td>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>1</td>\n<td>+2</td>\n<td>@Compendium[dnd5e.classfeatures.u4NLajXETJhJU31v]{Zauberwirken}, @Compendium[dnd5e.classfeatures.hpLNiGq7y67d2EHA]{Bardische Inspiration (W6)}</td>\n</tr>\n<tr>\n<td>2</td>\n<td>+2</td>\n<td>@Compendium[dnd5e.classfeatures.ezWijmCnlnQ9ZRX2]{Alleskönner}, @Compendium[dnd5e.classfeatures.he8RpPXwSl2lVSIk]{Lied der Erholung (W6)}</td>\n</tr>\n<tr>\n<td>3</td>\n<td>+2</td>\n<td>@Compendium[dnd5e.classfeatures.ILhzFHiRrqgQ9dFJ]{Bardenschule}, @Compendium[dnd5e.classfeatures.aQLg7BWdRnm4Hr9S]{Expertise}</td>\n</tr>\n<tr>\n<td>4</td>\n<td>+2</td>\n<td>@Compendium[dnd5e.classfeatures.s0Cc2zcX0JzIgam5]{Attributswerterhöhung}</td>\n</tr>\n<tr>\n<td>5</td>\n<td>+3</td>\n<td>@Compendium[dnd5e.classfeatures.hpLNiGq7y67d2EHA]{Bardische Inspiration (W8)}, @Compendium[dnd5e.classfeatures.3VDZGs5Ug3hIE322]{Quelle der Inspiration}</td>\n</tr>\n<tr>\n<td>6</td>\n<td>+3</td>\n<td>@Compendium[dnd5e.classfeatures.SEJmsjkEhdAZ90ki]{Bannlied}, Merkmal: Bardenschule</td>\n</tr>\n<tr>\n<td>7</td>\n<td>+3</td>\n<td>Zauber des 4. Grades</td>\n</tr>\n<tr>\n<td>8</td>\n<td>+3</td>\n<td>@Compendium[dnd5e.classfeatures.s0Cc2zcX0JzIgam5]{Attributswerterhöhung}</td>\n</tr>\n<tr>\n<td>9</td>\n<td>+4</td>\n<td>Zauber des 5. Grades, @Compendium[dnd5e.classfeatures.he8RpPXwSl2lVSIk]{Lied der Erholung (W8)}</td>\n</tr>\n<tr>\n<td>10</td>\n<td>+4</td>\n<td>@Compendium[dnd5e.classfeatures.hpLNiGq7y67d2EHA]{Bardische Inspiration (W10)}, @Compendium[dnd5e.classfeatures.aQLg7BWdRnm4Hr9S]{Expertise}, @Compendium[dnd5e.classfeatures.aonJ2YjkqkYB9WYB]{Magische Geheimnisse}</td>\n</tr>\n<tr>\n<td>11</td>\n<td>+4</td>\n<td>Zauber des 6. Grades</td>\n</tr>\n<tr>\n<td>12</td>\n<td>+4</td>\n<td>@Compendium[dnd5e.classfeatures.s0Cc2zcX0JzIgam5]{Attributswerterhöhung}</td>\n</tr>\n<tr>\n<td>13</td>\n<td>+5</td>\n<td>Zauber des 7. Grades, Slot@Compendium[dnd5e.classfeatures.he8RpPXwSl2lVSIk]{Lied der Erholung (W10)}</td>\n</tr>\n<tr>\n<td>14</td>\n<td>+5</td>\n<td>@Compendium[dnd5e.classfeatures.aonJ2YjkqkYB9WYB]{Magische Geheimnisse}, Merkmal: Bardenschule</td>\n</tr>\n<tr>\n<td>15</td>\n<td>+5</td>\n<td>Zauber des 8. Grades, @Compendium[dnd5e.classfeatures.hpLNiGq7y67d2EHA]{Bardische Inspiration (W12)}</td>\n</tr>\n<tr>\n<td>16</td>\n<td>+5</td>\n<td>@Compendium[dnd5e.classfeatures.s0Cc2zcX0JzIgam5]{Attributswerterhöhung}</td>\n</tr>\n<tr>\n<td>17</td>\n<td>+6</td>\n<td>Zauber des 9. Grades, @Compendium[dnd5e.classfeatures.he8RpPXwSl2lVSIk]{Lied der Erholung (W12)}</td>\n</tr>\n<tr>\n<td>18</td>\n<td>+6</td>\n<td>@Compendium[dnd5e.classfeatures.aonJ2YjkqkYB9WYB]{Magische Geheimnisse}</td>\n</tr>\n<tr>\n<td>19</td>\n<td>+6</td>\n<td>@Compendium[dnd5e.classfeatures.s0Cc2zcX0JzIgam5]{Attributswerterhöhung}</td>\n</tr>\n<tr>\n<td>20</td>\n<td>+6</td>\n<td>@Compendium[dnd5e.classfeatures.GBYN5rH4nh1ocRlY]{Überlegene Inspiration}</td>\n</tr>\n</tbody>\n</table>\n<h1>Bardenschulen</h1>\n<h2>Schule des Wissens</h2>\n<p>Barden, die sich dem Studium des Wissens widmen, verfügen über mannigfaltige Kenntnisse, die sie im Laufe ihrer Reisen aus der ganzen Welt zusammentragen. Dabei greifen sie auf alle nur möglichen Quellen zurück, vom akademischen Wälzer bis zum mündlich überlieferten Bauernmärchen. Ob sie nun eine volkstümliche Ballade in einer Taverne oder eine sorgfältig ausgearbeitete Komposition am königlichen Hof vortragen — diese Barden vermögen das Publikum mit ihrer Begabung in den Bann zu ziehen. Während der Applaus abebbt, finden sich die Zuhörer nicht selten in der Situation wieder, alles zu hinterfragen, was sie bisher für wahr gehalten haben, sei es ihr Glaube an die Priesterschaft des ortsansässigen Tempels oder ihre Loyalität gegenüber dem König.</p>\n<p>Die Treue des Barden gilt weder einer Krone noch den Lehren einer Gottheit, sie gilt allein der Beschäftigung mit dem Schönen und Wahren. Ein Adeliger, der solch einen Barden als Herold oder Berater beschäftigt, weiß, dass dieser sich eher aufrecht und ehrlich als diplomatisch verhalten wird.</p>\n<p>Die Anhänger dieser Schule versammeln sich in Bibliotheken und manchmal in richtigen Universitäten, in Hörsälen und Klassenzimmern, um ihr Wissen miteinander zu teilen. Sie treffen sich auch bei Staatsakten oder auf Festen, bei denen sie Korruption offenlegen, Lügen aufdecken und sich über wichtigtuerische Menschen und Autoritäten lustig machen können.</p>\n<h3>Schule des Wissens Merkmale</h3>\n<p>3. Stufe: @Compendium[dnd5e.classfeatures.e9ytGikyLFgwZ5wi]{Zusätzliche Übung}, @Compendium[dnd5e.classfeatures.5zPmHPQUne7RDfaU]{Schneidende Worte}</p>\n<p>6. Stufe: @Compendium[dnd5e.classfeatures.myBu3zi5eYvQIcuy]{Zusätzliche Magische Geheimnisse}</p>\n<p>14. Stufe: @Compendium[dnd5e.classfeatures.pquwueEMweRhiWaq]{Grenzenlose Begabung}</p>","chat":"","unidentified":""},"source":"SHB S. 51","identifier":"bard","levels":5,"hitDice":"d8","hitDiceUsed":0,"advancement":[{"_id":"0hib0tANlY63UbHm","type":"HitPoints","configuration":{},"value":{"1":"max","2":"avg","3":"avg","4":"avg","5":"avg"},"title":""},{"_id":"uXuCWgXNZYmfl1ll","type":"ScaleValue","configuration":{"distance":{"units":""},"identifier":"bardic-inspiration","type":"dice","scale":{"1":{"number":1,"faces":6},"5":{"number":1,"faces":8},"10":{"number":1,"faces":10},"15":{"number":1,"faces":12}}},"value":{},"title":"Bardic Inspiration"},{"_id":"K7LrYSL3MQ7p5051","type":"ScaleValue","configuration":{"distance":{"units":""},"identifier":"song-of-rest","type":"dice","scale":{"2":{"number":1,"faces":6},"9":{"number":1,"faces":8},"13":{"number":1,"faces":10},"17":{"number":1,"faces":12}}},"value":{},"title":"Song of Rest"}],"saves":["dex","cha"],"skills":{"number":3,"choices":["ath","acr","slt","ste","arc","his","inv","nat","rel","ani","ins","med","prc","sur","dec","itm","prf","per"],"value":["dec","med","prc"]},"spellcasting":{"progression":"full","ability":"cha"}},"flags":{"ddbimporter":{"id":141569506,"definitionId":1,"entityTypeId":1446578651,"type":"class","isStartingClass":true,"spellSlotDivisor":1,"spellCastingAbility":"cha","importId":"H5jtN7tByd3SNWB0"},"obsidian":{"source":{"type":"class","text":"Bard"}}},"img":"icons/skills/toxins/cup-goblet-poisoned-spilled.webp","effects":[],"_id":"YCEAw06KVgAuhL2A","folder":null,"sort":0,"ownership":{"default":0,"YzL2W1htQr2gHsBA":3},"_stats":{"systemId":"dnd5e","systemVersion":"2.2.2","coreVersion":"10.291","createdTime":1692382155107,"modifiedTime":1693094044146,"lastModifiedBy":"YzL2W1htQr2gHsBA"}},{"name":"Tieflinge","type":"feat","system":{"description":{"value":"<p><em>Als Folge ihrer infernalischen Abstammung teilen sich alle Tieflinge bestimmte Volksmerkmale. </em></p>\n<p><em><strong>Attributswerterhöhung: </strong></em> Dein Intelligenzwert wird um 1 Punkt erhöht, dein Charismawert um 2 Punkte.</p>\n<p><em><strong>Alter: </strong></em>  Tieflinge werden genauso schnell erwachsen wie Menschen, leben jedoch einige wenige Jahre länger.</p>\n<p><em><strong>Gesinnung: </strong></em> Tieflinge besitzen zwar keine angeborene Tendenz zum Bösen, doch viele von ihnen enden bei einer solchen Lebensanschauung. Böse oder nicht, ihre unabhängige Natur lässt sie oft eine chaotische Gesinnung annehmen. </p>\n<p><em><strong>Größe: </strong></em>  Tieflinge sind etwa so groß wie Menschen und ähnlich gebaut. Deine Größenkategorie ist mittelgroß.</p>\n<p><em><strong>Bewegungsrate: </strong></em>Deine Grundbewegungsrate beträgt 9 m.</p>\n<p><em><strong>Dunkelsicht: </strong></em> Dank deines infernalischen Erbes besitzt du eine überlegene Sicht in dunklen und dämmrigen Lichtverhältnissen. Behandle im Umkreis von 18 m dämmriges Licht wie helles Licht und Dunkelheit wie dämmriges Licht. Allerdings kannst du im Dunkeln keine Farben erkennen, nur Graustufen. </p>\n<p><em><strong>Höllische Resistenz: </strong></em>@Compendium[dnd5e.races.q71Pe1F8RRtEJt8Q] Du besitzt eine Resistenz gegen Feuerschaden.</p>\n<p><em><strong>Infernalisches Erbe: </strong></em> @Compendium[dnd5e.races.wJc88B8OP1y1xzMw] Du beherrschst den Zaubertrick @Compendium[dnd5e.spells.MUO1uYN7JR1hm4dR]. Ab der 3. Stufe kannst du dank dieses Merkmals den Spruch @Compendium[dnd5e.spells.22dPoeXfaaAv4K3h] des 2. Grades einmal wirken. Du musst eine lange Rast beenden, bevor du dies erneut kannst. Mit Erreichen der 5. Stufe bist du in der Lage, den Zauber @Compendium[dnd5e.spells.S7VbUetIfVT7B6Eq] auf die gleiche Weise einmal täglich einzusetzen. Das Attribut, mit dem du diese Zauber wirkst, ist Charisma.</p>\n<p><em><strong>Sprachen: </strong></em> Du kannst Infernalisch und die Gemeinsprache lesen, schreiben und sprechen. </p>","chat":"","unidentified":""},"source":"SHB S. 42","activation":{"type":"","cost":null,"condition":""},"duration":{"value":"","units":""},"cover":null,"crewed":false,"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"long":null,"units":""},"uses":{"value":null,"max":"","per":null,"recovery":""},"consume":{"type":"","target":null,"amount":null},"ability":null,"actionType":null,"attackBonus":"","chatFlavor":"","critical":{"threshold":null,"damage":""},"damage":{"parts":[],"versatile":""},"formula":"","save":{"ability":"","dc":null,"scaling":"spell"},"type":{"value":"race","subtype":""},"requirements":"","recharge":{"value":null,"charged":false}},"flags":{"ddbimporter":{"entityRaceId":7,"version":"3.4.57","baseName":"Tiefling","moreDetailsUrl":"/races/7-tiefling","baseRaceId":7,"baseRaceName":"Tiefling","fullName":"Tiefling","subRaceShortName":null,"isHomebrew":false,"isLegacy":false,"isSubRace":false,"featIds":[],"portraitAvatarUrl":"https://www.dndbeyond.com/avatars/9/388/636327461109911160.jpeg?width=1000&height=1000&fit=bounds&quality=95&auto=webp","avatarUrl":"https://www.dndbeyond.com/avatars/7/640/636287076637351751.png?width=350&height=350&fit=bounds&quality=95&auto=webp","largeAvatarUrl":"https://www.dndbeyond.com/avatars/7/641/636287076637981942.png?width=1000&height=1000&fit=bounds&quality=95&auto=webp"},"obsidian":{"source":{"type":"race"}}},"img":"https://www.dndbeyond.com/avatars/9/388/636327461109911160.jpeg?width=1000&height=1000&fit=bounds&quality=95&auto=webp","effects":[],"_id":"hxYkBInXHTTVGO49","folder":null,"sort":0,"ownership":{"default":0,"YzL2W1htQr2gHsBA":3},"_stats":{"systemId":"dnd5e","systemVersion":"2.2.2","coreVersion":"10.291","createdTime":1692382155166,"modifiedTime":1693094044147,"lastModifiedBy":"YzL2W1htQr2gHsBA"}},{"name":"Dunkelsicht","type":"feat","system":{"description":{"value":"<p>Du berührst eine bereitwillige Kreatur und verleihst ihr die Fähigkeit, in der Dunkelheit zu sehen. Für die Wirkungsdauer verfügt das Ziel über Dunkelsicht mit einer Reichweite von 18 m.</p>","chat":"","unidentified":""},"source":"SHB S. 223","activation":{"type":"","cost":null,"condition":""},"duration":{"value":"","units":""},"cover":null,"crewed":false,"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"long":null,"units":""},"uses":{"value":null,"max":"","per":null,"recovery":""},"consume":{"type":"","target":null,"amount":null},"ability":null,"actionType":null,"attackBonus":"","chatFlavor":"","critical":{"threshold":null,"damage":""},"damage":{"parts":[],"versatile":""},"formula":"","save":{"ability":"","dc":null,"scaling":"spell"},"type":{"value":"race","subtype":""},"requirements":"","recharge":{"value":null,"charged":false}},"flags":{"ddbimporter":{"id":60,"type":"race","entityTypeId":1960452172,"dndbeyond":{"displayOrder":6},"importId":"H5jtN7tByd3SNWB0"},"obsidian":{"source":{"type":"race"}}},"img":"icons/magic/perception/eye-ringed-glow-angry-small-red.webp","effects":[],"_id":"bVsnLi62gUkmyNBW","folder":null,"sort":0,"ownership":{"default":0,"YzL2W1htQr2gHsBA":3},"_stats":{"systemId":"dnd5e","systemVersion":"2.2.2","coreVersion":"10.291","createdTime":1692382155166,"modifiedTime":1693094044147,"lastModifiedBy":"YzL2W1htQr2gHsBA"}},{"name":"Höllische Resistenz","type":"feat","system":{"description":{"value":"<p>Du besitzt eine Resistenz gegen Feuerschaden.</p>","chat":"","unidentified":""},"source":"SHB S. 43","activation":{"type":"","cost":null,"condition":""},"duration":{"value":"","units":""},"cover":null,"crewed":false,"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"long":null,"units":""},"uses":{"value":null,"max":"","per":null,"recovery":""},"consume":{"type":"","target":null,"amount":null},"ability":null,"actionType":null,"attackBonus":"","chatFlavor":"","critical":{"threshold":null,"damage":""},"damage":{"parts":[],"versatile":""},"formula":"","save":{"ability":"","dc":null,"scaling":"spell"},"type":{"value":"race","subtype":""},"requirements":"","recharge":{"value":null,"charged":false}},"flags":{"ddbimporter":{"id":61,"type":"race","entityTypeId":1960452172,"dndbeyond":{"displayOrder":7},"importId":"H5jtN7tByd3SNWB0"},"obsidian":{"source":{"type":"race"}}},"img":"icons/magic/control/debuff-chains-shackle-movement-red.webp","effects":[],"_id":"csQmPyzVrYlHpP6A","folder":null,"sort":0,"ownership":{"default":0,"YzL2W1htQr2gHsBA":3},"_stats":{"systemId":"dnd5e","systemVersion":"2.2.2","coreVersion":"10.291","createdTime":1692382155167,"modifiedTime":1693094044148,"lastModifiedBy":"YzL2W1htQr2gHsBA"}},{"name":"Infernalisches Erbe","type":"feat","system":{"description":{"value":"<p>Du beherrschst den Zaubertrick @Compendium[dnd5e.spells.MUO1uYN7JR1hm4dR]. Ab der 3. Stufe kannst du dank dieses Merkmals den Spruch @Compendium[dnd5e.spells.22dPoeXfaaAv4K3h] des 2. Grades einmal wirken. Du musst eine lange Rast beenden, bevor du dies erneut kannst. Mit Erreichen der 5. Stufe bist du in der Lage, den Zauber @Compendium[dnd5e.spells.S7VbUetIfVT7B6Eq] auf die gleiche Weise einmal täglich einzusetzen. Das Attribut, mit dem du diese Zauber wirkst, ist Charisma.</p>","chat":"","unidentified":""},"source":"SHB S. 43","activation":{"type":"","cost":null,"condition":""},"duration":{"value":"","units":""},"cover":null,"crewed":false,"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"long":null,"units":""},"uses":{"value":null,"max":"","per":null,"recovery":""},"consume":{"type":"","target":null,"amount":null},"ability":null,"actionType":null,"attackBonus":"","chatFlavor":"","critical":{"threshold":null,"damage":""},"damage":{"parts":[],"versatile":""},"formula":"","save":{"ability":"","dc":null,"scaling":"spell"},"type":{"value":"race","subtype":""},"requirements":"","recharge":{"value":null,"charged":false}},"flags":{"ddbimporter":{"id":62,"type":"race","entityTypeId":1960452172,"dndbeyond":{"displayOrder":8},"importId":"H5jtN7tByd3SNWB0"},"obsidian":{"source":{"type":"race"}}},"img":"icons/sundries/scrolls/scroll-symbol-triangle-brown.webp","effects":[],"_id":"3E5PotRELimAgoTH","folder":null,"sort":0,"ownership":{"default":0,"YzL2W1htQr2gHsBA":3},"_stats":{"systemId":"dnd5e","systemVersion":"2.2.2","coreVersion":"10.291","createdTime":1692382155167,"modifiedTime":1693094044148,"lastModifiedBy":"YzL2W1htQr2gHsBA"}},{"name":"Zauberwirken","type":"feat","system":{"description":{"value":"<p>Die {creature} ist ein Zauberwirker der 1. Stufe. Ihr Attribut zum Zauberwirken ist Weisheit (Zauberrettungswurf-SG 12, +4 zum Treffen mit Zauberangriffen). Sie hat die folgenden Klerikerzauber vorbereitet:</p>\n<p>Zaubertricks (beliebig oft): </p>\n<p>1. Grad (3 Plätze): </p>","chat":"","unidentified":""},"source":"Bard","activation":{"type":"","cost":null,"condition":""},"duration":{"value":"","units":""},"cover":null,"crewed":false,"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"long":null,"units":""},"uses":{"value":null,"max":"","per":null,"recovery":""},"consume":{"type":"","target":null,"amount":null},"ability":null,"actionType":null,"attackBonus":"","chatFlavor":"","critical":{"threshold":null,"damage":""},"damage":{"parts":[],"versatile":""},"formula":"","save":{"ability":"","dc":null,"scaling":"spell"},"type":{"value":"class","subtype":""},"requirements":"","recharge":{"value":null,"charged":false}},"flags":{"ddbimporter":{"id":74,"type":"class","dndbeyond":{"requiredLevel":1,"displayOrder":3,"levelScale":null,"levelScales":[],"limitedUse":[],"class":"Bard"},"class":"Bard","subclass":"College of Lore","importId":"H5jtN7tByd3SNWB0"},"obsidian":{"source":{"type":"class","text":"Bard"}}},"img":"icons/magic/light/beam-rays-orange-large.webp","effects":[],"_id":"qFmttM4AtBfbtpqW","folder":null,"sort":0,"ownership":{"default":0,"YzL2W1htQr2gHsBA":3},"_stats":{"systemId":"dnd5e","systemVersion":"2.2.2","coreVersion":"10.291","createdTime":1692382155169,"modifiedTime":1693094044148,"lastModifiedBy":"YzL2W1htQr2gHsBA"}},{"name":"Alleskönner","type":"feat","system":{"description":{"value":"<p>Ab der 2. Stufe kannst du deinen halben Übungsbonus (abgerundet) auf jeden Attributswurf addieren, der nicht bereits durch deinen Übungsbonus verbessert wird.</p>","chat":"","unidentified":""},"source":"SHB S. 54","activation":{"type":"","cost":null,"condition":""},"duration":{"value":"","units":""},"cover":null,"crewed":false,"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"long":null,"units":""},"uses":{"value":null,"max":"","per":null,"recovery":""},"consume":{"type":"","target":null,"amount":null},"ability":null,"actionType":null,"attackBonus":"","chatFlavor":"","critical":{"threshold":null,"damage":""},"damage":{"parts":[],"versatile":""},"formula":"","save":{"ability":"","dc":null,"scaling":"spell"},"type":{"value":"class","subtype":""},"requirements":"","recharge":{"value":null,"charged":false}},"flags":{"ddbimporter":{"id":79,"type":"class","dndbeyond":{"requiredLevel":2,"displayOrder":5,"levelScale":null,"levelScales":[],"limitedUse":[],"class":"Bard"},"class":"Bard","subclass":"College of Lore","importId":"H5jtN7tByd3SNWB0"},"obsidian":{"source":{"type":"class","text":"Bard"}}},"img":"icons/commodities/tech/cog-steel.webp","effects":[],"_id":"baqyYAE4Q3lDOm5e","folder":null,"sort":0,"ownership":{"default":0,"YzL2W1htQr2gHsBA":3},"_stats":{"systemId":"dnd5e","systemVersion":"2.2.2","coreVersion":"10.291","createdTime":1692382155170,"modifiedTime":1693094044148,"lastModifiedBy":"YzL2W1htQr2gHsBA"}},{"name":"Lied der Erholung","type":"feat","system":{"description":{"value":"<p>Von der 2. Stufe an kannst du während einer kurzen Rast mit sanfter Musik oder Gesängen den Heilungsprozess deiner verwundeten Verbündeten beschleunigen.</p>\n<p>Wenn du oder eine befreundete Kreatur durch das Ausgeben von Trefferwürfeln zum Ende einer kurzen Rast Trefferpunkte wiedererlangt, erhält der Betroffene 1W6 zusätzliche Trefferpunkte zurück. Die befreundete Kreatur muss deine Darbietung hören können, um von diesem Effekt zu profitieren.</p>\n<p>Die zusätzlichen Trefferpunkte erhöhen sich mit dem Aufstieg in dieser Klasse: ab der 9. Stufe auf 1W8, ab der 13. Stufe auf 1W10 und ab der 17. Stufe auf 1W12.</p>","chat":"","unidentified":""},"source":"SHB S. 54","activation":{"type":"","cost":null,"condition":""},"duration":{"value":"","units"