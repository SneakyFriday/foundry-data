0,"modifiedTime":1693096574646,"lastModifiedBy":"YzL2W1htQr2gHsBA"}},{"name":"Rucksack","type":"backpack","system":{"description":{"value":"<p>Ein Rucksack hat 30 Liter Fassungsvermögen oder kann 30 Pfund / 14 Kg Ausrüstung aufnehmen. Du kannst auch Gegenstände außen an dem Rucksack festzurren, wie etwa einen Schlafsack oder ein Seil.</p>","chat":"","unidentified":"Gear"},"source":"SHB S. 153","quantity":1,"weight":5,"price":{"value":2,"denomination":"gp"},"attunement":0,"equipped":true,"rarity":"","identified":true,"capacity":{"type":"weight","value":30,"weightless":false},"currency":{"cp":0,"sp":0,"ep":0,"gp":0,"pp":0}},"flags":{"ddbimporter":{"dndbeyond":{"type":"Adventuring Gear","isConsumable":false,"isContainer":true,"isCustomItem":false,"isHomebrew":false,"isMonkWeapon":false,"isPack":false,"levelInfusionGranted":null,"tags":["Container"],"sources":[{"sourceId":1,"pageNumber":null,"sourceType":2},{"sourceId":2,"pageNumber":null,"sourceType":1}]},"id":1180894703,"entityTypeId":1439493548,"containerEntityId":105192794,"containerEntityTypeId":1581111423,"definitionEntityTypeId":2103445194,"definitionId":20,"originalName":"Backpack","version":"3.4.57","importId":"iSN0AbFB6inuPU5r"},"infusions":{"maps":[],"applied":[],"infused":false}},"effects":[],"img":"icons/containers/bags/pack-rounded-leather-brown.webp","_id":"vPUfLH7FyqQewEv1","folder":null,"sort":0,"ownership":{"default":0,"YzL2W1htQr2gHsBA":3},"_stats":{"systemId":"dnd5e","systemVersion":"2.2.2","coreVersion":"10.291","createdTime":1692381686861,"modifiedTime":1693094014395,"lastModifiedBy":"YzL2W1htQr2gHsBA"}},{"name":"Clothes, Common","type":"loot","system":{"description":{"value":"<p>This set of clothes could consist of a loose shirt and baggy breeches, or a loose shirt and skirt or overdress. Cloth wrappings are used for shoes.</p>","chat":"","unidentified":"Gear"},"source":"Basic Rules, Player's Handbook","quantity":1,"weight":3,"price":{"value":0.5,"denomination":"gp"},"attunement":0,"equipped":fals