:"2.2.2","coreVersion":"10.291","createdTime":1693093830198,"modifiedTime":1693155379344,"lastModifiedBy":"YzL2W1htQr2gHsBA"},"_id":"s7u16w0EZpExRzmM"},{"name":"Eckzähne einer Vampirbrut","type":"loot","img":"icons/svg/item-bag.svg","system":{"description":{"value":"<p>Die spitzen Eckzähne einer blutsaugenden Vampirbrut</p>","chat":"","unidentified":""},"source":"","quantity":1,"weight":0,"price":{"value":0,"denomination":"gp"},"attunement":0,"equipped":false,"rarity":"uncommon","identified":true},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"YzL2W1htQr2gHsBA":3},"flags":{"core":{"sourceId":"Item.OMi0SmdOw6lJ8vKV"}},"_stats":{"systemId":"dnd5e","systemVersion":"2.2.2","coreVersion":"10.291","createdTime":1693093915389,"modifiedTime":1693155392704,"lastModifiedBy":"YzL2W1htQr2gHsBA"},"_id":"VbEa7clqGBJGAVup"},{"folder":"UO4yPbBbDFmW8Pjo","name":"Militärabzeichen","type":"loot","img":"Icons/Items/TDV_Emblem_New.png","system":{"description":{"value":"<p>Ein Militärabzeichen, erbeutet von einem Soldaten, der in der Schlacht bezwungen wurde.</p><p><strong>Rang</strong>: Hauptmann</p>","chat":"","unidentified":""},"source":"","quantity":1,"weight":0,"price":{"value":0,"denomination":"gp"},"attunement":0,"equipped":false,"rarity":"common","identified":true},"effects":[],"sort":0,"ownership":{"default":0,"YzL2W1htQr2gHsBA":3},"flags":{"core":{"sourceId":"Item.JmioGKhNCPZIogZA"}},"_stats":{"systemId":"dnd5e","systemVersion":"2.2.2","coreVersion":"10.291","createdTime":1693090189090,"modifiedTime":1693155402460,"lastModifiedBy":"YzL2W1htQr2gHsBA"},"_id":"DPSw5RBnyxzfQyhk"},{"folder":"UO4yPbBbDFmW8Pjo","name":"Orkhauer","type":"loot","img":"icons/svg/item-bag.svg","system":{"description":{"value":"<h2>Orkhauer (auf Schnur aufgezogen)</h2><p>Aus dem Mund eines Orks geschlagen und auf eine Schnur gezogen, um diese als Trophäe tragen zu können.</p>","chat":"","unidentified":""},"source":"","quantity":1,"weight":0,"price":{"value":0,"denomination":"gp"},"attunement":0,"equipped":false,"rarity":"","identified":true},"effects":[],"sort":0,"ownership":{"default":0,"YzL2W1htQr2gHsBA":3},"flags":{"core":{"sourceId":"Item.f6KWXsnAIHw7ZDuG"}},"_stats":{"systemId":"dnd5e","systemVersion":"2.2.2","coreVersion":"10.291","createdTime":1693090757720,"modifiedTime":1693155404636,"lastModifiedBy":"YzL2W1htQr2gHsBA"},"_id":"JrB3mz2TH3TsEuCY"},{"name":"Steine der Verständigung (Stein A)","type":"loot","img":"icons/svg/item-bag.svg","system":{"description":{"value":"<p>Steine der Verständigung kommen in Paaren von zwei glatten Steinen vor, die so geformt wurden, dass sie einander gleichen. So können sie leicht als Paar identifiziert werden. Wenn du einen Stein berührst, kannst du eine Aktion verwenden, um damit den Zauber @UUID[Item.N2qcpOAJ31cFiMfb]{Verständigung } zu wirken. Das Ziel ist der Träger des anderen Steins.</p><p>Wenn der andere Stein von keiner Kreatur getragen wird, weißt du das, sobald du den Stein berührst, ohne dafür den Zauber wirken zu müssen.</p><p>Sobald <em>Verständigung</em> mittels der Steine gewirkt wurde, können sie bis zur nächsten Morgendämmerung nicht erneut verwendet werden. Wenn einer der Steine des Paars zerstört wird, wird der andere nicht-magisch.</p>","chat":"","unidentified":""},"source":"","quantity":1,"weight":0,"price":{"value":0,"denomination":"gp"},"attunement":0,"equipped":false,"rarity":"uncommon","identified":true},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"YzL2W1htQr2gHsBA":3},"flags":{"core":{"sourceId":"Item.Oi1P639Hnp9FFerC"}},"_stats":{"systemId":"dnd5e","systemVersion":"2.2.2","coreVersion":"10.291","createdTime":1693093356842,"modifiedTime":1693155419655,"lastModifiedBy":"YzL2W1htQr2gHsBA"},"_id":"gqjQ1xgaRW2I9hF4"},{"name":"Druidenkette mit aufgereihten ZÄhnen","type":"loot","system":{"description":{"value":"","chat":"","unidentified":""},"source":"Druide im Weingut Weinmagier","quantity":1,"weight":0,"price":{"value":0,"denomination":"gp"},"attunement":0,"equipped":false