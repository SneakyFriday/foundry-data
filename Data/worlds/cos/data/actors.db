em></p>\n<p><em>Die rote Flüssigkeit des Tranks schimmert, wenn sie bewegt wird.</em></p>\n<p>Du erhältst 2W4 + 2 Trefferpunkte zurück, wenn du diesen Trank trinkst.</p>","chat":"","unidentified":""},"source":"SLH S. 166","quantity":1,"weight":0.1,"price":{"value":50,"denomination":"gp"},"attunement":0,"equipped":false,"rarity":"common","identified":true,"activation":{"type":"action","cost":1,"condition":""},"duration":{"value":"","units":""},"cover":null,"crewed":false,"target":{"value":1,"width":null,"units":"","type":"creature"},"range":{"value":null,"long":null,"units":"touch"},"uses":{"value":1,"max":"1","per":"charges","recovery":"","autoDestroy":true},"consume":{"type":"","target":null,"amount":null},"ability":"","actionType":"heal","attackBonus":"","chatFlavor":"","critical":{"threshold":null,"damage":""},"damage":{"parts":[["2d4 + 2","healing"]],"versatile":""},"formula":"","save":{"ability":"","dc":null,"scaling":"spell"},"consumableType":"potion"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"YzL2W1htQr2gHsBA":3},"flags":{"babele":{"translated":true,"hasTranslation":true,"originalName":"Potion of Healing"},"core":{"sourceId":"Compendium.dnd5e.items.ytlsBjYsZ7OBSEBs"}},"_stats":{"systemId":"dnd5e","systemVersion":"2.2.2","coreVersion":"10.291","createdTime":1661787233972,"modifiedTime":1693094865117,"lastModifiedBy":"YzL2W1htQr2gHsBA"}},{"_id":"KAsWNYLmrK2MQ2Bl","name":"Flöte","type":"tool","img":"icons/tools/instruments/flute-simple-wood.webp","system":{"description":{"value":"<p>Eine Flöte, die Ehrfurcht, Verwunderung oder Furcht in Ihrem Publikum hervorruft.</p>\n<p>Bist du im Umgang mit einem Musikinstrument geübt, darfst du deinen Übungsbonus auf alle Attributs- und Fertigkeitswürfe addieren, die mit dem Spielen des Instruments in Verbindung stehen. Ein Barde kann sein Instrument als Zauberfokus, anstelle einer Materialkomponente, für die keine Kosten aufgeführt sind, verwenden. Jedes Musikinstrument benötigt seine eigene Übung.</p>","chat":"","unidentified":""},"source":"SHB S. 154","quantity":1,"weight":1,"price":{"value":2,"denomination":"gp"},"attunement":0,"equipped":false,"rarity":"common","identified":true,"toolType":"music","baseItem":"flute","ability":"cha","chatFlavor":"","proficient":0,"bonus":""},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"YzL2W1htQr2gHsBA":3},"flags":{"babele":{"translated":true,"hasTranslation":true,"originalName":"Flute"},"core":{"sourceId":"Compendium.dnd5e.items.eJOrPcAz9EcquyRQ"}},"_stats":{"systemId":"dnd5e","systemVersion":"2.2.2","coreVersion":"10.291","createdTime":1661787233781,"modifiedTime":1693094890747,"lastModifiedBy":"YzL2W1htQr2gHsBA"}},{"_id":"cey3Z8nwvJ4wcbB4","name":"Panflöte","type":"tool","img":"icons/tools/instruments/flute-simple-wood.webp","system":{"description":{"value":"<p>Eine Panflöte, die Ehrfurcht, Verwunderung oder Furcht in Ihrem Publikum hervorruft.</p>\n<p>Bist du im Umgang mit einem Musikinstrument geübt, darfst du deinen Übungsbonus auf alle Attributs- und Fertigkeitswürfe addieren, die mit dem Spielen des Instruments in Verbindung stehen. Ein Barde kann sein Instrument als Zauberfokus, anstelle einer Materialkomponente, für die keine Kosten aufgeführt sind, verwenden. Jedes Musikinstrument benötigt seine eigene Übung.</p>","chat":"","unidentified":""},"source":"SHB S. 154","quantity":1,"weight":2,"price":{"value":12,"denomination":"gp"},"attunement":0,"equipped":false,"rarity":"common","identified":true,"toolType":"music","baseItem":"flute","ability":"cha","chatFlavor":"","proficient":0,"bonus":""},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"YzL2W1htQr2gHsBA":3},"flags":{"babele":{"translated":true,"hasTranslation":true,"originalName":"Pan Flute"},"core":{"sourceId":"Compendium.dnd5e.items.G5m5gYIx9VAUWC3J"}},"_stats":{"systemId":"dnd5e","systemVersion":"2.2.2","coreVersion":"10.291","createdTime":1661787233553,"modifiedTime":1693094896974,"lastModifiedBy":"YzL2W1htQr2gHsBA"}},{"name":"Holzpfl