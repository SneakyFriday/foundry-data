ws":0,"animation":{"type":null,"speed":5,"intensity":5,"reverse":false},"darkness":{"min":0,"max":1}},"sight":{"enabled":false,"range":null,"angle":360,"visionMode":"basic","color":null,"attenuation":0.1,"brightness":0,"saturation":0,"contrast":0},"detectionModes":[],"flags":{},"actorId":"KJgAwKaoXbOkrCGA","x":4270,"y":4340,"hidden":true,"actorData":{},"elevation":0,"effects":[],"overlayEffect":"","_id":"G319shoXZQFYRKtg"},{"name":"Akteur (14)","displayName":0,"actorLink":false,"texture":{"src":"Monsters/Hell/Cambino_Astarte.png","scaleX":1,"scaleY":1,"offsetX":0,"offsetY":0,"rotation":0,"tint":null},"width":1,"height":1,"lockRotation":false,"rotation":0,"alpha":1,"disposition":-1,"displayBars":0,"bar1":{"attribute":"attributes.hp"},"bar2":{"attribute":null},"light":{"alpha":0.5,"angle":360,"bright":0,"color":null,"coloration":1,"dim":0,"attenuation":0.5,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"type":null,"speed":5,"intensity":5,"reverse":false},"darkness":{"min":0,"max":1}},"sight":{"enabled":false,"range":null,"angle":360,"visionMode":"basic","color":null,"attenuation":0.1,"brightness":0,"saturation":0,"contrast":0},"detectionModes":[],"flags":{},"actorId":"ORh73835tkEdsaIb","x":4340,"y":4200,"hidden":true,"_id":"xQ6ZSisNVJO6HkFP","actorData":{"system":{"details":{"biography":{"value":"<p><span style=\"font-family: Söhne, ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, Ubuntu, Cantarell, 'Noto Sans', sans-serif, 'Helvetica Neue', Arial, 'Apple Color Emoji', 'Segoe UI Emoji', 'Segoe UI Symbol', 'Noto Color Emoji'\">Plötzlich, aus dem Zentrum des Kreises, steigt eine weibliche Kreatur empor. Ihre Haut brennt in einem infernalischen Rot, und ihre kleinen, scharfen Teufelshörner ragen finster aus ihrem pechschwarzen Haar. Sie trägt ein Gewand, das so dunkel ist wie die finstersten Abgründe der Hölle und mit obskuren Symbolen durchzogen ist. Ihre Augen funkeln verführerisch, aber in ihrem Blick liegt eine gefährliche Entschlossenheit, die das Herz erstarren lässt.</span></p><p><span style=\"font-family: Söhne, ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, Ubuntu, Cantarell, 'Noto Sans', sans-serif, 'Helvetica Neue', Arial, 'Apple Color Emoji', 'Segoe UI Emoji', 'Segoe UI Symbol', 'Noto Color Emoji'\">Die Frau lächelt euch herausfordernd an, ihre Lippen geschmückt mit einem blutroten Lippenstift. Ihre Stimme ist verführerisch, aber durchdrungen von finsterer Überzeugung, als sie euch anspricht. Ihr spürt, dass sie nicht ohne Grund in diesem finsteren Ritual herbeigerufen wurde und dass sie ihre eigenen düsteren Absichten verfolgt.</span></p><p><span style=\"font-family: Söhne, ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, Ubuntu, Cantarell, 'Noto Sans', sans-serif, 'Helvetica Neue', Arial, 'Apple Color Emoji', 'Segoe UI Emoji', 'Segoe UI Symbol', 'Noto Color Emoji'\">Während sie aus dem Beschwörungskreis tritt, bringt die sie eine unheilvolle Aura der Verlockung und Bedrohung mit sich, die das Rebenfeld um sie herum verwelken und verdorren lässt.</span></p>"}},"attributes":{"hp":{"temp":"","tempmax":""}}}},"elevation":0,"effects":[],"overlayEffect":""},{"name":"Nadelplage","displayName":0,"actorLink":false,"texture":{"src":"Chapters/12.%20Weingut%20Weinmagier/Tokens/Nadelplage.png","scaleX":1,"scaleY":1,"offsetX":0,"offsetY":0,"rotation":0,"tint":null},"width":1,"height":1,"lockRotation":false,"rotation":0,"alpha":1,"disposition":-1,"displayBars":0,"bar1":{"attribute":"attributes.hp"},"bar2":{"attribute":null},"light":{"alpha":0.5,"angle":360,"bright":0,"color":null,"coloration":1,"dim":0,"attenuation":0.5,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"type":null,"speed":5,"intensity":5,"reverse":false},"darkness":{"min":0,"max":1}},"sight":{"enabled":false,"range":null,"angle":360,"visionMode":"basic","color":null,"attenuation":0.1,"brightness":0,"saturation":0,"contrast":0},"detectionModes":[],"flags":{},"actorId":"DD9ors4YUPbWwvli",