{"name":"Holzpflock","type":"weapon","img":"icons/svg/item-bag.svg","system":{"description":{"value":"<p>Ein Holzpflock, grob an einer Seite zu einer Spitze geschnitzt. Der Feind jeden Vampirs oder Gottgesandten.</p>","chat":"","unidentified":""},"source":"","quantity":1,"weight":0.5,"price":{"value":0,"denomination":"gp"},"attunement":0,"equipped":false,"rarity":"common","identified":true,"activation":{"type":"","cost":null,"condition":""},"duration":{"value":"","units":""},"cover":null,"crewed":false,"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"long":null,"units":""},"uses":{"value":null,"max":"","per":null,"recovery":""},"consume":{"type":"","target":null,"amount":null},"ability":"","actionType":"mwak","attackBonus":"","chatFlavor":"","critical":{"threshold":null,"damage":""},"damage":{"parts":[["1d4","piercing"]],"versatile":""},"formula":"","save":{"ability":"","dc":null,"scaling":"spell"},"armor":{"value":null},"hp":{"value":null,"max":null,"dt":null,"conditions":""},"weaponType":"simpleM","baseItem":"","properties":{"ada":false,"fir":false,"fin":false,"foc":false,"lod":false,"lgt":true,"mgc":false,"amm":false,"rel":false,"hvy":false,"spc":false,"sil":false,"ver":false,"rch":false,"ret":false,"thr":false,"two":false},"proficient":false},"effects":[],"folder":null,"sort":300000,"ownership":{"default":0,"YzL2W1htQr2gHsBA":3},"flags":{},"_stats":{"systemId":"dnd5e","systemVersion":"2.2.2","coreVersion":"10.291","createdTime":1693092117967,"modifiedTime":1693093069546,"lastModifiedBy":"YzL2W1htQr2gHsBA"},"_id":"zwcoGsDRBbXlNHAy"}
