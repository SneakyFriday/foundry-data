{"user":"y8opEFHvV7c7QIhq","type":0,"content":"<div class=\"dnd5e chat-card item-card\" data-actor-id=\"I4EU9sR5qy78aWKc\" data-item-id=\"DBTTwd9lKzNfWVTi\">\n    <header class=\"card-header flexrow\">\n        <img src=\"icons/weapons/axes/axe-broad-black.webp\" title=\"Handaxe\" width=\"36\" height=\"36\" />\n        <h3 class=\"item-name\">Handaxe</h3>\n    </header>\n\n    <div class=\"card-content\">\n        <p>Proficiency with a handaxe allows you to add your proficiency bonus to the attack roll for any attack you make with it.</p>\n    </div>\n\n    <div class=\"card-buttons\">\n        <button data-action=\"attack\">Angriff</button>\n\n        <button data-action=\"damage\">\n            Schaden\n        </button>\n\n\n\n\n\n\n    </div>\n\n    <footer class=\"card-footer\">\n        <span>Einfache Waffe Nah.</span>\n        <span>Nicht angelegt</span>\n        <span>Geübt</span>\n        <span>1 Aktion</span>\n        <span>20 / 60 Fuß</span>\n    </footer>\n</div>","flavor":"Handaxe","speaker":{"scene":"tC1Y4Abty0mca6rt","token":"cnnBZYZ2oZ0urr2a","actor":"I4EU9sR5qy78aWKc","alias":"Barogart"},"flags":{"core":{"canPopout":true},"dnd5e":{"use":{"type":"weapon","itemId":"DBTTwd9lKzNfWVTi","itemUuid":"Actor.I4EU9sR5qy78aWKc.Item.DBTTwd9lKzNfWVTi"}}},"whisper":[],"blind":false,"timestamp":1693165352789,"rolls":[],"sound":null,"emote":false,"_id":"HkvkuFAF3vGvrStZ"}
