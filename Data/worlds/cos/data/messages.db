{"user":"y8opEFHvV7c7QIhq","type":5,"content":"10","sound":"sounds/dice.wav","speaker":{"scene":"SSWWGKvqtyDQf1CK","token":"FSpp1Yy50aag68bv","actor":"I4EU9sR5qy78aWKc","alias":"Barogart"},"flags":{"dnd5e":{"roll":{"type":"save","abilityId":"con"}}},"flavor":"Konstitution Rettungswurf","rolls":["{\"class\":\"D20Roll\",\"options\":{\"flavor\":\"Konstitution Rettungswurf\",\"advantageMode\":0,\"defaultRollMode\":\"publicroll\",\"rollMode\":\"publicroll\",\"critical\":20,\"fumble\":1,\"halflingLucky\":false,\"configured\":true},\"dice\":[],\"formula\":\"1d20 + 3 + 3\",\"terms\":[{\"class\":\"Die\",\"options\":{\"critical\":20,\"fumble\":1},\"evaluated\":true,\"number\":1,\"faces\":20,\"modifiers\":[],\"results\":[{\"result\":4,\"active\":true}]},{\"class\":\"OperatorTerm\",\"options\":{},\"evaluated\":true,\"operator\":\"+\"},{\"class\":\"NumericTerm\",\"options\":{},\"evaluated\":true,\"number\":3},{\"class\":\"OperatorTerm\",\"options\":{},\"evaluated\":true,\"operator\":\"+\"},{\"class\":\"NumericTerm\",\"options\":{},\"evaluated\":true,\"number\":3}],\"total\":10,\"evaluated\":true}"],"timestamp":1695501537631,"whisper":[],"blind":false,"emote":false,"_id":"yuRfKQXgNRT1JjM1"}
{"user":"y8opEFHvV7c7QIhq","type":0,"content":"<div class=\"dnd5e chat-card item-card\" data-actor-id=\"I4EU9sR5qy78aWKc\" data-item-id=\"JrM0eRUcVtohHmU6\">\n    <header class=\"card-header flexrow\">\n        <img src=\"icons/weapons/hammers/hammer-double-stone.webp\" title=\"Kriegshammer\" width=\"36\" height=\"36\" />\n        <h3 class=\"item-name\">Kriegshammer</h3>\n    </header>\n\n    <div class=\"card-content\">\n        <p>Ein schwerer Metallhammer, der mit einer Hand und einem Schild oder mit zwei Händen geführt werden kann, um vernichtende Schläge auszuführen.</p>\n    </div>\n\n    <div class=\"card-buttons\">\n        <button data-action=\"attack\">Angriff</button>\n\n        <button data-action=\"damage\">\n            Schaden\n        </button>\n\n        <button data-action=\"versatile\">Vielseitig</button>\n\n\n\n\n\n    </div>\n\n    <footer class=\"card-footer\">\n        <span>Kriegswaffe Nah.</span>\n        <span>Angelegt</span>\n        <span>Geübt</span>\n        <span>1 Aktion</span>\n        <span>5 Fuß</span>\n    </footer>\n</div>","flavor":"Kriegshammer","speaker":{"scene":"tC1Y4Abty0mca6rt","token":"UJhcQLD6lGCiyWlG","actor":"I4EU9sR5qy78aWKc","alias":"Barogart"},"flags":{"core":{"canPopout":true},"dnd5e":{"use":{"type":"weapon","itemId":"JrM0eRUcVtohHmU6","itemUuid":"Actor.I4EU9sR5qy78aWKc.Item.JrM0eRUcVtohHmU6"}}},"whisper":[],"blind":false,"timestamp":1692391956124,"rolls":[],"sound":null,"emote":false,"_id":"ywCDaehhGtR4cweJ"}
{"user":"sjYkV3qNoQe97JYZ","content":"Schutzwind<br />Hervorrufung2<br />Zeitaufwand:1 Aktion<br />Reichweite:Selbst<br />Ziel:<br />Komponenten: V<br />Wirkungsdauer:<br />Beschreibung:<br />Ein starker Wind (32 Kilometer pro Stunde) weht in einem Radius von 3 Metern um dich herum, bewegt sich mit dir und bleibt auf dich zentriert. Der Wind hält für die Dauer des Zaubers an.<br />Er macht dich und andere Kreaturen in seinem Bereich taub.<br />Er löscht ungeschützte Flammen von der Größe einer Fackel oder kleiner in seinem Bereich.<br />Das Gebiet ist schwieriges Terrain für andere Kreaturen als dich.<br />Die Angriffswürfe von Angriffen mit Fernkampfwaffen haben Nachteil, wenn sie durch den Wind hindurchgehen.<br />Sie vertreibt Dampf, Gas und Nebel, die durch starken Wind zerstreut werden können.","type":1,"timestamp":1692392348776,"flavor":"","speaker":{"scene":null,"actor":null,"token":null,"alias":""},"whisper":[],"blind":false,"rolls":[],"sound":null,"emote":false,"flags":{},"_id":"z1YJxjIrZwK6mF8t"}
