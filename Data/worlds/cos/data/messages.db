{"user":"YzL2W1htQr2gHsBA","type":0,"content":"<div class=\"dnd5e chat-card item-card\" data-actor-id=\"M5XbQbRORb4C853n\" data-item-id=\"H5jjhM0nWxRbvzM5\" data-token-id=\"Scene.tC1Y4Abty0mca6rt.Token.WCqdd1SP4uSowvaH\">\n    <header class=\"card-header flexrow\">\n        <img src=\"icons/svg/item-bag.svg\" title=\"Klauen\" width=\"36\" height=\"36\" />\n        <h3 class=\"item-name\">Klauen</h3>\n    </header>\n\n    <div class=\"card-content\">\n        \n    </div>\n\n    <div class=\"card-buttons\">\n        <button data-action=\"attack\">Angriff</button>\n\n        <button data-action=\"damage\">\n            Schaden\n        </button>\n\n\n\n\n\n\n    </div>\n\n    <footer class=\"card-footer\">\n        <span>Einfache Waffe Nah.</span>\n        <span>Angelegt</span>\n        <span>Geübt</span>\n    </footer>\n</div>","flavor":"Klauen","speaker":{"scene":"tC1Y4Abty0mca6rt","token":"WCqdd1SP4uSowvaH","actor":"M5XbQbRORb4C853n","alias":"Zweigplage"},"flags":{"core":{"canPopout":true},"dnd5e":{"use":{"type":"weapon","itemId":"H5jjhM0nWxRbvzM5","itemUuid":"Scene.tC1Y4Abty0mca6rt.Token.WCqdd1SP4uSowvaH.Item.H5jjhM0nWxRbvzM5"}}},"whisper":[],"blind":false,"timestamp":1693166299024,"rolls":[],"sound":null,"emote":false,"_id":"jk90xcxTsc6B5oxj"}
{"user":"y8opEFHvV7c7QIhq","type":0,"content":"<div class=\"dnd5e chat-card item-card\" data-actor-id=\"I4EU9sR5qy78aWKc\" data-item-id=\"JrM0eRUcVtohHmU6\">\n    <header class=\"card-header flexrow\">\n        <img src=\"icons/weapons/hammers/hammer-double-stone.webp\" title=\"Kriegshammer\" width=\"36\" height=\"36\" />\n        <h3 class=\"item-name\">Kriegshammer</h3>\n    </header>\n\n    <div class=\"card-content\">\n        <p>Ein schwerer Metallhammer, der mit einer Hand und einem Schild oder mit zwei Händen geführt werden kann, um vernichtende Schläge auszuführen.</p>\n    </div>\n\n    <div class=\"card-buttons\">\n        <button data-action=\"attack\">Angriff</button>\n\n        <button data-action=\"damage\">\n            Schaden\n        </button>\n\n        <button data-action=\"versatile\">Vielseitig</button>\n\n\n\n\n\n    </div>\n\n    <footer class=\"card-footer\">\n        <span>Kriegswaffe Nah.</span>\n        <span>Angelegt</span>\n        <span>Geübt</span>\n        <span>1 Aktion</span>\n        <span>5 Fuß</span>\n    </footer>\n</div>","flavor":"Kriegshammer","speaker":{"scene":"tC1Y4Abty0mca6rt","token":"UJhcQLD6lGCiyWlG","actor":"I4EU9sR5qy78aWKc","alias":"Barogart"},"flags":{"core":{"canPopout":true},"dnd5e":{"use":{"type":"weapon","itemId":"JrM0eRUcVtohHmU6","itemUuid":"Actor.I4EU9sR5qy78aWKc.Item.JrM0eRUcVtohHmU6"}}},"whisper":[],"blind":false,"timestamp":1692393485222,"rolls":[],"sound":null,"emote":false,"_id":"kYoQgnf1zBf7wzsD"}
