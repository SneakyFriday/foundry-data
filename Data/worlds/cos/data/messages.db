{"user":"y8opEFHvV7c7QIhq","type":0,"content":"<div class=\"dnd5e chat-card item-card\" data-actor-id=\"I4EU9sR5qy78aWKc\" data-item-id=\"9bScFq1HcnjZwEqa\">\n    <header class=\"card-header flexrow\">\n        <img src=\"icons/magic/fire/dagger-rune-enchant-flame-orange.webp\" title=\"Extra Attack\" width=\"36\" height=\"36\" />\n        <h3 class=\"item-name\">Extra Attack</h3>\n    </header>\n\n    <div class=\"card-content\">\n        You can attack twice whenever you take the Attack action on your turn.\n<details>\n  <summary>\n    More Details\n  </summary>\n  <p>\n    </p><p>Beginning at 5th level, you can attack twice, instead of once, whenever you take the Attack action on your turn.</p>\n<p>The number of attacks increases to three when you reach 11th level in this class and to four when you reach 20th level in this class.</p>\n  <p></p>\n</details>\n    </div>\n\n    <div class=\"card-buttons\">\n        \n\n\n\n\n\n\n\n    </div>\n\n    <footer class=\"card-footer\">\n        <span>Fuß</span>\n    </footer>\n</div>","flavor":"Extra Attack","speaker":{"scene":"tC1Y4Abty0mca6rt","token":"9jOsurtGWbeaAkoj","actor":"I4EU9sR5qy78aWKc","alias":"Barogart"},"flags":{"core":{"canPopout":true},"dnd5e":{"use":{"type":"feat","itemId":"9bScFq1HcnjZwEqa","itemUuid":"Actor.I4EU9sR5qy78aWKc.Item.9bScFq1HcnjZwEqa"}}},"whisper":[],"blind":false,"timestamp":1695496433965,"rolls":[],"sound":null,"emote":false,"_id":"OoMVRx8tIr70MXXt"}
