{"user":"d7Jxxn5B6j1l4Shx","type":0,"content":"<div class=\"dnd5e chat-card item-card\" data-actor-id=\"Pfum2reDti6NVXIv\" data-item-id=\"MYF7OQK3rh3CePwO\" data-spell-level=\"2\">\n    <header class=\"card-header flexrow\">\n        <img src=\"icons/magic/light/beam-rays-red.webp\" title=\"Sengender Strahl\" width=\"36\" height=\"36\" />\n        <h3 class=\"item-name\">Sengender Strahl</h3>\n    </header>\n\n    <div class=\"card-content\">\n        <p>Du erschaffst drei Strahlen aus Feuer und schleuderst sie auf ein oder mehrere Ziele in Reichweite. Fernkampf-Zauberangriff für jeden Strahl aus. Bei einem Treffer erleidet das Ziel 2W6 Feuerschaden.</p><p><strong>Auf höheren Graden: </strong>Wenn du diesen Spruch mit einem Zauberplatz des 3. oder eines höheren Grades wirkst, erschaffst du für jeden Grad über den 2. hinaus einen zusätzlichen Strahl.</p>\n    </div>\n\n    <div class=\"card-buttons\">\n        <button data-action=\"attack\">Angriff</button>\n\n        <button data-action=\"damage\">\n            Schaden\n        </button>\n\n\n\n\n\n\n    </div>\n\n    <footer class=\"card-footer\">\n        <span>2. Grad</span>\n        <span>V und G</span>\n        <span>1 Aktion</span>\n        <span>1 Kreatur</span>\n        <span>36 Meter</span>\n    </footer>\n</div>","flavor":"Sengender Strahl","speaker":{"scene":"tC1Y4Abty0mca6rt","token":"lfX4TBQPJrDxEtuR","actor":"Pfum2reDti6NVXIv","alias":"Erevan"},"flags":{"core":{"canPopout":true},"dnd5e":{"use":{"type":"spell","itemId":"MYF7OQK3rh3CePwO","itemUuid":"Actor.Pfum2reDti6NVXIv.Item.MYF7OQK3rh3CePwO","spellLevel":2}}},"whisper":[],"blind":false,"timestamp":1693164054202,"rolls":[],"sound":null,"emote":false,"_id":"ovodz4Dy8MCicBK7"}
{"user":"YzL2W1htQr2gHsBA","type":0,"content":"<div class=\"dnd5e chat-card item-card\" data-actor-id=\"A5IeHKtNjkPknnmg\" data-item-id=\"4rmhxRDDmKVDHXNT\">\n    <header class=\"card-header flexrow\">\n        <img src=\"icons/svg/item-bag.svg\" title=\"Umschlingen\" width=\"36\" height=\"36\" />\n        <h3 class=\"item-name\">Umschlingen</h3>\n    </header>\n\n    <div class=\"card-content\">\n        \n    </div>\n\n    <div class=\"card-buttons\">\n        <button data-action=\"attack\">Angriff</button>\n\n        <button data-action=\"damage\">\n            Schaden\n        </button>\n\n\n        <button data-action=\"save\" data-ability=\"str\">\n            Rettungswurf SG 12 Stärke\n        </button>\n\n\n\n\n    </div>\n\n    <footer class=\"card-footer\">\n        <span>Einfache Waffe Nah.</span>\n        <span>Angelegt</span>\n        <span>Geübt</span>\n    </footer>\n</div>","flavor":"Umschlingen","speaker":{"scene":"tC1Y4Abty0mca6rt","token":"2y3aKbw16QPHy4Ga","actor":"A5IeHKtNjkPknnmg","alias":"Rankenplage"},"flags":{"core":{"canPopout":true},"dnd5e":{"use":{"type":"weapon","itemId":"4rmhxRDDmKVDHXNT","itemUuid":"Actor.A5IeHKtNjkPknnmg.Item.4rmhxRDDmKVDHXNT"}}},"whisper":[],"blind":false,"timestamp":1692392209733,"rolls":[],"sound":null,"emote":false,"_id":"oxdw8aaqFkkPUqNy"}
