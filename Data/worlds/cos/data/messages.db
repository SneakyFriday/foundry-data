{"user":"y8opEFHvV7c7QIhq","type":5,"content":"14","sound":"sounds/dice.wav","speaker":{"scene":"SSWWGKvqtyDQf1CK","token":"FSpp1Yy50aag68bv","actor":"I4EU9sR5qy78aWKc","alias":"Barogart"},"flags":{"dnd5e":{"roll":{"type":"skill","skillId":"ste"}}},"flavor":"Heimlichkeit Fertigkeitswurf (Geschicklichkeit)","rolls":["{\"class\":\"D20Roll\",\"options\":{\"flavor\":\"Heimlichkeit Fertigkeitswurf (Geschicklichkeit)\",\"advantageMode\":0,\"defaultRollMode\":\"publicroll\",\"rollMode\":\"publicroll\",\"critical\":20,\"fumble\":1,\"halflingLucky\":false,\"reliableTalent\":false,\"configured\":true},\"dice\":[],\"formula\":\"1d20 + 0 + 0\",\"terms\":[{\"class\":\"Die\",\"options\":{\"critical\":20,\"fumble\":1},\"evaluated\":true,\"number\":1,\"faces\":20,\"modifiers\":[],\"results\":[{\"result\":14,\"active\":true}]},{\"class\":\"OperatorTerm\",\"options\":{},\"evaluated\":true,\"operator\":\"+\"},{\"class\":\"NumericTerm\",\"options\":{},\"evaluated\":true,\"number\":0},{\"class\":\"OperatorTerm\",\"options\":{},\"evaluated\":true,\"operator\":\"+\"},{\"class\":\"NumericTerm\",\"options\":{},\"evaluated\":true,\"number\":0}],\"total\":14,\"evaluated\":true}"],"timestamp":1695499992082,"whisper":[],"blind":false,"emote":false,"_id":"n0YXPkZIdplJ3XBq"}
{"whisper":["sjYkV3qNoQe97JYZ"],"speaker":{"alias":"Dice So Nice!","scene":null,"actor":null,"token":null},"flags":{"core":{"canPopout":true}},"content":"<div class=\"dice-so-nice\">\n                    <h3 class=\"nue\">Dice So Nice - Deine 3D-Würfel</h3>\n                    <p class=\"nue\">Es scheint, als benutzt du 3D Würfel zum ersteln mal in dieser Welt.</p>\n                    <p class=\"nue\">Du kannst deine 3D-Würfel konfigurieren (oder deaktivieren), indem du auf diese Schaltfläche klickst:</p>\n                    <p>\n                        <button type=\"button\" class=\"dice-so-nice-btn-settings\" data-key=\"dice-so-nice.dice-so-nice\">\n                            <i class=\"fas fa-dice-d20\"></i> 3D-Würfel Einstellungen\n                        </button>\n                    </p>\n                    <p class=\"nue\">Du kannst diese Einstellungen jederzeit unter 'Einstellungen anpassen' &gt; 'Moduleinstellungen' &gt; 'Dice So Nice!' ändern</p>\n                    <p class=\"nue\">Um eine kurze Tour durch die Funktionen von \"Dice so Nice\" zu erhalten, rufe dein Tour Management Fenster auf oder drücke auf diesen Knopf.</p>\n                    <p>\n                        <button type=\"button\" class=\"dice-so-nice-btn-tour\" data-tour=\"dice-so-nice-tour\">\n                            <i class=\"fas fa-hiking\"></i> Schau dir das Tutorial an (45s)\n                        </button>\n                    </p>\n                    <p class=\"nue\">Du wirst diese Nachricht nicht erneut angezeigt bekommen. Fröhliches Würfeln!</p>\n                    <footer class=\"nue\"><i class=\"fas fa-info-circle\"></i> Diese Chatkarte kann mittels Rechtsklick in einem eigenen Fenster geöffnet werden. Alternativ kannst du mit einem Rechtsklick auf die Sprechblase am oberen Rand den gesamten Chat-Reiter herauslösen. Selbiges kannst du auch mit allen anderen Reitern der Seitenleiste tun.</footer>\n                </div>","type":0,"user":"sjYkV3qNoQe97JYZ","timestamp":1692382714500,"flavor":"","blind":false,"rolls":[],"sound":null,"emote":false,"_id":"n7I9wVr0vAlfe12N"}
{"user":"YzL2W1htQr2gHsBA","type":0,"content":"<div class=\"dnd5e chat-card item-card\" data-actor-id=\"A5IeHKtNjkPknnmg\" data-item-id=\"4rmhxRDDmKVDHXNT\" data-token-id=\"Scene.tC1Y4Abty0mca6rt.Token.YeM67e0XJrWO41bZ\">\n    <header class=\"card-header flexrow\">\n        <img src=\"icons/svg/item-bag.svg\" title=\"Umschlingen\" width=\"36\" height=\"36\" />\n        <h3 class=\"item-name\">Umschlingen</h3>\n    </header>\n\n    <div class=\"card-content\">\n        \n    </div>\n\n    <div class=\"card-buttons\">\n        <button data-action=\"attack\">Angriff</button>\n\n        <button data-action=\"damage\">\n            Schaden\n        </button>\n\n\n        <button data-action=\"save\" data-ability=\"str\">\n            Rettungswurf SG 12 Stärke\n        </button>\n\n\n\n\n    </div>\n\n    <footer class=\"card-footer\">\n        <span>Einfache Waffe Nah.</span>\n        <span>Angelegt</span>\n        <span>Geübt</span>\n    </footer>\n</div>","flavor":"Umschlingen","speaker":{"scene":"tC1Y4Abty0mca6rt","token":"YeM67e0XJrWO41bZ","actor":"A5IeHKtNjkPknnmg","alias":"Rankenplage"},"flags":{"core":{"canPopout":true},"dnd5e":{"use":{"type":"weapon","itemId":"4rmhxRDDmKVDHXNT","itemUuid":"Scene.tC1Y4Abty0mca6rt.Token.YeM67e0XJrWO41bZ.Item.4rmhxRDDmKVDHXNT"}}},"whisper":[],"blind":false,"timestamp":1695496607709,"rolls":[],"sound":null,"emote":false,"_id":"nDoTbQ146ktHq7DV"}
